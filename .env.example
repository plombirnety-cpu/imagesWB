ANTHROPIC_API_KEY=
POLLINATIONS_TOKEN=
GEMINI_API_KEY=

# Лёгкий парольный экран веб-панели. Указывать только SHA-256 пароля (64 hex),
# не сам пароль. Пусто — защита отключена. COOKIE_SECURE включать только с HTTPS.
PANEL_ACCESS_PASSWORD_SHA256=
PANEL_AUTH_COOKIE_SECURE=off

# Ключ Google Cloud (YouTube Data API v3) — используется соседним trend-watch/pop_watch.py
# для источника youtube в pop-трендах. Опционально: бесплатный ключ, оформляется в Google
# Cloud Console (включить YouTube Data API v3). Без него YouTube-источник pop-трендов
# просто пропускается (graceful degradation), остальные источники (anilist/jikan/gtrends)
# работают как обычно.
YOUTUBE_API_KEY=

# Ключ TMDB (themoviedb.org, бесплатная регистрация) — источник tmdb в pop-трендах:
# кино/сериалы/дорамы, тренды дня с русскими названиями. Без ключа источник пропускается.
# Также используется franchise_scout.py::_tmdb_credits для неаниме-франшиз (сериалы/
# дорамы/фильмы) — тот же ключ, отдельно заводить не нужно.
TMDB_API_KEY=

# Ключ Кинопоиска (kinopoiskapiunofficial.tech, бесплатный тир) — источник kinopoisk
# в pop-трендах. Опционально, без ключа пропускается.
KINOPOISK_API_KEY=

# Модель Claude для арт-директора — используется, ТОЛЬКО когда
# ART_DIRECTOR_PROVIDER=anthropic (см. ниже).
MODEL=claude-sonnet-4-6

# ── Провайдер LLM арт-директора (llm_provider.py) ────────────────────────────
# Арт-директор (идея принта/промпт/слоган/kana в art_director.py, синтез досье
# франшизы в franchise_scout.py) НЕ завязан жёстко на Anthropic — провайдер
# переключаемый.

# gemini (ДЕФОЛТ) — Google Gemini текстом, тот же ключ GEMINI_API_KEY, что уже
# используется для картинок (провайдер картинок IMAGE_PROVIDER ниже) — дешевле
# и не требует отдельного баланса Anthropic | openai — OpenAI chat.completions
# (нужен OPENAI_API_KEY) | anthropic — старое поведение 1:1 (нужен
# ANTHROPIC_API_KEY выше, модель MODEL выше).
ART_DIRECTOR_PROVIDER=gemini

# Модель Gemini для ART_DIRECTOR_PROVIDER=gemini. Если когда-то начнёт отдавать
# HTTP 404 "not found" (Google ротирует версионные имена без предупреждения,
# см. providers.py про _OCR_MODEL) — поставить актуальный алиас сюда, без
# правки кода.
ART_DIRECTOR_MODEL=gemini-pro-latest

# Ключ/модель OpenAI — нужны, ТОЛЬКО если ART_DIRECTOR_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Бренд-лейбл подвала-этикетки типографики v3 (collection_footer, см. PRINT_STYLE_GUIDE.md).
# ПУСТОЙ по умолчанию — бренд на принты не наносим (правка владельца), подвал = TITLE | CHARACTER.
BRAND_LABEL=

# gemini (ДЕФОЛТ — в 4-7 раз дешевле Pollinations на объёме 500 принтов/день) |
# pollinations — выбор реализации в providers.py.
IMAGE_PROVIDER=gemini

# Модель Pollinations под nano-banana.
POLLINATIONS_MODEL=nanobanana

# Модель Gemini (nano-banana напрямую, без SDK). Дефолт gemini-3.1-flash-image
# (Nano Banana 2) — A/B оркестратора подтвердил лучшее качество встроенного текста
# и гармоничность композиции против gemini-2.5-flash-image при той же цене.
GEMINI_MODEL=gemini-3.1-flash-image

# Премиум-модель Gemini (Nano Banana Pro) — задел на будущее, параметр model у
# providers.generate_image её поддерживает, использование НЕ обязательно в этом заходе.
GEMINI_MODEL_PREMIUM=gemini-3-pro-image

# image (ДЕФОЛТ) — текст встраивается ПРЯМО в генерацию nano-banana (exact-spelling
# промпт-блок, art_director.py), typography-код НЕ накладывает текст поверх (только
# диекат-вырезка как есть) | code — старый путь: генерация без текста, типографика
# кодом (typography_v3/typography), используется как фолбэк при провале OCR-контроля
# спеллинга (batch_print._verify_text).
TEXT_RENDER=image

IMG_SIZE=1536

# ── Апскейл до печатных 300 DPI (upscale.py, portable realesrgan-ncnn-vulkan) ───

# on (ДЕФОЛТ) — сохраняет <tag>_print.png = апскейл x4 (realesrgan-x4plus-anime)
# поверх diecut. Требует tools/realesrgan/ (portable exe + модели, см. upscale.py
# докстринг — НЕ в git, качается отдельно с github.com/xinntao/Real-ESRGAN/releases);
# без exe апскейл сам себя пропускает с предупреждением, пайплайн не падает.
# Замер (2026-07-09, встроенная AMD GPU через Vulkan): ~55-65с/шт, в пределах 90с.
UPSCALE=on

# Модель realesrgan-ncnn-vulkan (см. tools/realesrgan/models/).
UPSCALE_MODEL=realesrgan-x4plus-anime

# Кратность апскейла (2/3/4).
UPSCALE_SCALE=4

# Минимальный размер БОЛЬШЕЙ стороны <tag>_print.png в пикселях — x4 realesrgan не
# гарантирует единый печатный минимум на всех дизайнах (nano-banana отдаёт исходники
# разного размера, 768..1408px наблюдалось живьём). Если после x4 большая сторона
# всё ещё меньше — досчитывается PIL Lanczos поверх (upscale.py). Дефолт 3800px.
PRINT_MIN_SIDE=3800

# Таймаут ОДНОГО вызова realesrgan-ncnn-vulkan.exe (секунд). Апскейлы между
# воркерами сериализуются (см. upscale.py, GPU не делится параллельными вызовами
# без деградации — соло ~55-65с/шт, при WORKERS=4 без сериализации 94-115с/шт с
# риском таймаута) — 300 с запасом даже при нескольких воркерах в очереди.
UPSCALE_TIMEOUT=300

# Минимальная доля высоты кадра, которую обязан занимать bbox альфы вырезанной
# фигуры — меньше -> попытка бракуется как "фигура слишком мелкая" (QC-ретрай).
FIGURE_MIN_FRAC=0.55

# on (ДЕФОЛТ) — vision-QC-гейт анатомии рук: для фигуративных персонажей дешёвая
# текстовая модель Gemini считает руки/кисти и ловит аномалии (лишняя/отсутствующая
# рука, сросшиеся пальцы) — тот же ретрай-цикл, что OCR/coverage/масштаб фигуры,
# best-effort (не блокирует выпуск, если чисто не вышло за все попытки). КАЖДЫЙ
# vision-вызов = +1 запрос к дневной RPD-квоте Gemini, отдельно от квоты OCR-контроля
# спеллинга. off — гейт пропускается целиком (например когда дневная квота Gemini
# уже на исходе) — промпт-усиление (art_director._ANATOMY_BLOCK) при этом продолжает
# работать всегда, бесплатно, независимо от этого флага.
ANATOMY_QC=on

# ── Ежедневный контур (theme_scout.py / daily_prints.py) ────────────────────────

# Путь к соседнему проекту trend-watch/ (источник CSV-трендов + subprocess-парсеры).
TREND_WATCH_DIR=../trend-watch

# Сколько принтов делать за один дневной прогон.
PRINTS_PER_DAY=500

# Параллельные генерации (ThreadPoolExecutor) в daily_prints.py.
WORKERS=4

# Предохранитель дневного бюджета в USD — план обрезается перед стартом.
MAX_DAILY_COST_USD=50

# Для скольких самых высокоскоровых аниме-тайтлов дня theme_scout.py запускает
# глубокое досье franchise_scout.build_dossier (измеренная популярность персонажей)
# перед вызовом тематизатора. Каждое досье с реальным YouTube-сигналом стоит ~101
# юнит квоты YouTube (100 search.list + 1 videos.list) — см. README.md.
FRANCHISE_DEEP_N=3

# Потолок СОВОКУПНОЙ сметы мега-партии mega_batch_run.py (USD): страховка по всем
# прогонам вместе (накопленное читается из <outroot>/_journal.jsonl). В смету идут
# только попытки, где Gemini ФАКТИЧЕСКИ отдал картинку — 429/500 без изображения
# с баланса реально не списываются; QC-ретраи с полученной картинкой считаются.
MEGA_BUDGET_CAP_USD=150
