ANTHROPIC_API_KEY=
POLLINATIONS_TOKEN=
GEMINI_API_KEY=

# Ключ Google Cloud (YouTube Data API v3) — используется соседним trend-watch/pop_watch.py
# для источника youtube в pop-трендах. Опционально: бесплатный ключ, оформляется в Google
# Cloud Console (включить YouTube Data API v3). Без него YouTube-источник pop-трендов
# просто пропускается (graceful degradation), остальные источники (anilist/jikan/gtrends)
# работают как обычно.
YOUTUBE_API_KEY=

# Модель Claude для арт-директора.
MODEL=claude-sonnet-4-6

# gemini (ДЕФОЛТ — в 4-7 раз дешевле Pollinations на объёме 500 принтов/день) |
# pollinations — выбор реализации в providers.py.
IMAGE_PROVIDER=gemini

# Модель Pollinations под nano-banana.
POLLINATIONS_MODEL=nanobanana

# Модель Gemini (nano-banana напрямую, без SDK).
GEMINI_MODEL=gemini-2.5-flash-image

IMG_SIZE=1536

# ── Ежедневный контур (theme_scout.py / daily_prints.py) ────────────────────────

# Путь к соседнему проекту trend-watch/ (источник CSV-трендов + subprocess-парсеры).
TREND_WATCH_DIR=../trend-watch

# Сколько принтов делать за один дневной прогон.
PRINTS_PER_DAY=500

# Параллельные генерации (ThreadPoolExecutor) в daily_prints.py.
WORKERS=4

# Предохранитель дневного бюджета в USD — план обрезается перед стартом.
MAX_DAILY_COST_USD=50
